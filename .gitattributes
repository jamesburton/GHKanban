# Normalise line endings — silences Git's CRLF↔LF conversion warnings on Windows.
* text=auto eol=lf

# Source code: always LF
*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.slnx  text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.razor text eol=lf
*.css   text eol=lf
*.props text eol=lf
*.config text eol=lf

# Binary
*.nupkg binary
*.png   binary
*.jpg   binary
*.ico   binary
